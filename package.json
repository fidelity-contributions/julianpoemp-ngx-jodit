{
  "name": "jodit",
  "version": "0.0.0",
  "scripts": {
    "ng": "nx",
    "postinstall": "node ./decorate-angular-cli.js",
    "start": "nx serve demo",
    "start:pro": "nx serve demo-pro",
    "build": "nx build",
    "build:lib": "nx build ngx-jodit",
    "release:lib": "nx run ngx-jodit:version --releaseAs=patch --push",
    "publish:lib": "nx npm ngx-jodit",
    "build:lib:pro": "nx build ngx-jodit-pro",
    "release:lib:pro": "nx run ngx-jodit-pro:version --releaseAs=patch --push",
    "publish:lib:pro": "nx npm ngx-jodit-pro",
    "build:docs": "nx build demo && mv -f ./dist/apps/demo/* ./docs",
    "update": "nx migrate latest",
    "migrate": "npx nx migrate --run-migrations",
    "test": "nx test"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "21.2.9",
    "@angular/common": "21.2.9",
    "@angular/compiler": "21.2.9",
    "@angular/core": "21.2.9",
    "@angular/forms": "21.2.9",
    "@angular/platform-browser": "21.2.9",
    "@angular/platform-browser-dynamic": "21.2.9",
    "@angular/router": "21.2.9",
    "@nx/angular": "22.7.1",
    "bootstrap": "^5.2.2",
    "bootstrap-icons": "^1.9.1",
    "jodit": "^4.7.9",
    "jodit-pro": "^4.7.6",
    "rxjs": "7.8.1",
    "tslib": "^2.3.0",
    "zone.js": "0.16.2"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "21.2.9",
    "@angular-devkit/core": "21.2.9",
    "@angular-devkit/schematics": "21.2.9",
    "@angular-eslint/eslint-plugin": "21.3.1",
    "@angular-eslint/eslint-plugin-template": "21.3.1",
    "@angular-eslint/template-parser": "21.3.1",
    "@angular/cli": "21.2.10",
    "@angular/compiler-cli": "21.2.9",
    "@angular/language-service": "21.2.9",
    "@commitlint/cli": "^17.0.0",
    "@commitlint/config-angular": "^17.0.0",
    "@jscutlery/semver": "^5.7.1",
    "@nx/cypress": "22.7.1",
    "@nx/eslint": "22.7.1",
    "@nx/eslint-plugin": "22.7.1",
    "@nx/jest": "22.7.1",
    "@nx/js": "22.7.1",
    "@nx/workspace": "22.7.1",
    "@schematics/angular": "21.2.9",
    "@types/jest": "30.0.0",
    "@types/node": "18.16.9",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@typescript-eslint/utils": "^8.59.2",
    "ajv": "^8.12.0",
    "autoprefixer": "^10.4.0",
    "cypress": "15.9.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-cypress": "^6.4.1",
    "husky": "^8.0.0",
    "jest": "30.4.2",
    "jest-environment-jsdom": "30.4.1",
    "jest-preset-angular": "16.0.0",
    "jest-util": "30.4.1",
    "ng-packagr": "21.2.3",
    "ngx-deploy-npm": "^9.0.0",
